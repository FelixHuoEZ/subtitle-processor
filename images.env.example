# Example config for scripts/build-and-push.sh
# Copy this file to images.env and adjust values before running the script.

# Registry/namespace prefix (registry[:port]/namespace)
# Example: docker.io/myteam/subtitle or 10.0.0.23:5443/subtitle
IMAGE_PREFIX=my-registry/subtitle

# Optional mirror prefix for upstream base images used by the Dockerfiles.
# Example: 10.0.0.23:5443/dockerhub
# BASE_IMAGE_REGISTRY=10.0.0.23:5443/dockerhub

# Optional CA bundle for a self-signed IMAGE_PREFIX registry.
# When omitted, the script auto-detects ~/.docker/certs.d/<registry>/ca.crt
# REGISTRY_CA_FILE=/Users/you/.docker/certs.d/10.0.0.23:5443/ca.crt

# Optional explicit tag (defaults to current git short SHA)
# IMAGE_TAG=latest

# Set to false to skip pushing (images will be loaded locally instead)
PUSH=true

# Target platforms for buildx (single or comma separated list)
# PLATFORMS=linux/amd64,linux/arm64

# Optional additional tags to publish (comma separated, e.g. latest,prod)
# EXTRA_TAGS=latest

# Optional proxy envs injected into the buildx builder container.
# BUILDER_HTTP_PROXY=http://127.0.0.1:10808
# BUILDER_HTTPS_PROXY=http://127.0.0.1:10808
